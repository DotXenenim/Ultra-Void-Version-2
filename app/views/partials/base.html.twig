<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}dontgetdeported.nl{% endblock %}</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        navy:    { DEFAULT: '#1B2A4A', dark: '#152238', light: '#243560' },
                        crimson: { DEFAULT: '#C0392B', dark: '#A93226', light: '#E74C3C' },
                        slate:   { card: '#8B9BB4', border: '#D6DCE8', bg: '#EEF1F7' },
                    },
                    fontFamily: { sans: ['Inter', 'system-ui', 'sans-serif'] }
                }
            }
        }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>body { font-family: 'Inter', sans-serif; }</style>
    {% block head %}{% endblock %}
</head>
<body class="bg-slate-bg min-h-screen flex flex-col">

<nav class="bg-navy shadow-lg sticky top-0 z-50">
    <div class="max-w-5xl mx-auto px-4 flex items-center justify-between h-16">
        <a href="/" class="flex items-center">
            <span class="text-crimson font-bold text-lg">dont</span><span class="text-white font-bold text-lg">getdeported</span><span class="text-slate-card font-light text-lg">.nl</span>
        </a>
        <div class="flex items-center gap-4 text-sm">
            {% if user %}
                <span class="text-slate-card hidden sm:inline">Hi, {{ user.first_name }}</span>
                <a href="/checklist" class="text-white font-medium hover:text-slate-card transition-colors">My Checklist</a>
                <a href="/logout" class="text-slate-card hover:text-white transition-colors">Log out</a>
            {% else %}
                <a href="/login" class="text-slate-card hover:text-white transition-colors">Log in</a>
                <a href="/register" class="bg-crimson hover:bg-crimson-dark text-white font-semibold px-4 py-2 rounded-lg transition-colors">Get started</a>
            {% endif %}
        </div>
    </div>
</nav>

<main class="flex-1">
    {% block content %}{% endblock %}
</main>

<footer class="bg-navy py-8 mt-auto">
    <div class="max-w-5xl mx-auto px-4 text-center">
        <p class="text-slate-card text-sm">
            <span class="text-crimson font-semibold">dont</span><span class="text-white font-semibold">getdeported</span><span class="text-slate-card">.nl</span>
            &nbsp;&mdash;&nbsp; Helping international students settle in the Netherlands.
        </p>
        <p class="text-slate-card text-xs mt-1 opacity-60">
            Information only &mdash; not legal or immigration advice. Always verify with official Dutch government sources.
        </p>
    </div>
</footer>

{% block scripts %}{% endblock %}
</body>
</html>
