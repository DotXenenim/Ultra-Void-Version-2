{% extends 'partials/base.html.twig' %}
{% block title %}Create your account — dontgetdeported.nl{% endblock %}

{% block content %}
<div class="min-h-screen flex items-center justify-center px-4 py-12">
    <div class="w-full max-w-md">
        <div class="text-center mb-8">
            <h1 class="text-3xl font-extrabold text-navy">Create your account</h1>
            <p class="text-slate-card mt-2 text-sm">We'll use this to save your personalised checklist.</p>
        </div>

        <div class="bg-white rounded-2xl shadow-lg p-8">
            {% if errors.general is defined %}
                <div class="bg-crimson bg-opacity-10 border border-crimson text-crimson text-sm rounded-lg px-4 py-3 mb-6">
                    {{ errors.general }}
                </div>
            {% endif %}

            <form method="POST" action="/register" novalidate>
                {{ csrf_input() }}

                <div class="grid grid-cols-2 gap-4 mb-4">
                    <div>
                        <label class="block text-xs font-semibold text-navy uppercase tracking-wide mb-1" for="first_name">First name</label>
                        <input type="text" id="first_name" name="first_name"
                               value="{{ first_name ?? '' }}"
                               class="w-full border {% if errors.first_name is defined %}border-crimson{% else %}border-slate-border{% endif %} rounded-lg px-4 py-3 text-navy text-sm focus:outline-none focus:ring-2 focus:ring-navy"
                               required>
                        {% if errors.first_name is defined %}
                            <p class="text-crimson text-xs mt-1">{{ errors.first_name }}</p>
                        {% endif %}
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-navy uppercase tracking-wide mb-1" for="last_name">Last name</label>
                        <input type="text" id="last_name" name="last_name"
                               value="{{ last_name ?? '' }}"
                               class="w-full border {% if errors.last_name is defined %}border-crimson{% else %}border-slate-border{% endif %} rounded-lg px-4 py-3 text-navy text-sm focus:outline-none focus:ring-2 focus:ring-navy"
                               required>
                        {% if errors.last_name is defined %}
                            <p class="text-crimson text-xs mt-1">{{ errors.last_name }}</p>
                        {% endif %}
                    </div>
                </div>

                <div class="mb-4">
                    <label class="block text-xs font-semibold text-navy uppercase tracking-wide mb-1" for="email">Email address</label>
                    <input type="email" id="email" name="email"
                           value="{{ email ?? '' }}"
                           class="w-full border {% if errors.email is defined %}border-crimson{% else %}border-slate-border{% endif %} rounded-lg px-4 py-3 text-navy text-sm focus:outline-none focus:ring-2 focus:ring-navy"
                           required>
                    {% if errors.email is defined %}
                        <p class="text-crimson text-xs mt-1">{{ errors.email }}</p>
                    {% endif %}
                </div>

                <div class="mb-4">
                    <label class="block text-xs font-semibold text-navy uppercase tracking-wide mb-1" for="password">Password</label>
                    <input type="password" id="password" name="password"
                           class="w-full border {% if errors.password is defined %}border-crimson{% else %}border-slate-border{% endif %} rounded-lg px-4 py-3 text-navy text-sm focus:outline-none focus:ring-2 focus:ring-navy"
                           required>
                    {% if errors.password is defined %}
                        <p class="text-crimson text-xs mt-1">{{ errors.password }}</p>
                    {% endif %}
                </div>

                <div class="mb-6">
                    <label class="block text-xs font-semibold text-navy uppercase tracking-wide mb-1" for="confirm_password">Confirm password</label>
                    <input type="password" id="confirm_password" name="confirm_password"
                           class="w-full border {% if errors.confirm_password is defined %}border-crimson{% else %}border-slate-border{% endif %} rounded-lg px-4 py-3 text-navy text-sm focus:outline-none focus:ring-2 focus:ring-navy"
                           required>
                    {% if errors.confirm_password is defined %}
                        <p class="text-crimson text-xs mt-1">{{ errors.confirm_password }}</p>
                    {% endif %}
                </div>

                <button type="submit"
                        class="w-full bg-navy hover:bg-navy-dark text-white font-bold py-3 rounded-xl transition-colors text-sm">
                    Create account &amp; continue
                </button>
            </form>

            <p class="text-center text-slate-card text-sm mt-6">
                Already have an account?
                <a href="/login" class="text-crimson font-semibold hover:underline">Log in</a>
            </p>
        </div>
    </div>
</div>
{% endblock %}
